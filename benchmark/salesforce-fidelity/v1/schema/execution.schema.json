{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jataka.io/schemas/salesforce-fidelity-execution-v1.json",
  "title": "Jataka Salesforce Fidelity Execution Descriptor v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "case_id",
    "mode",
    "patch_contract",
    "package",
    "apex",
    "queries",
    "seed",
    "metadata_probe",
    "browser",
    "event_replay",
    "evidence",
    "prerequisites"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "case_id": {"type": "string", "pattern": "^SF-FID-[0-9]{3}$"},
    "mode": {
      "enum": ["deploy_and_test", "metadata_probe", "event_replay_adapter"]
    },
    "patch_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["output_format", "raw_text_forbidden", "sha256"],
      "properties": {
        "output_format": {"const": "jataka.ast.instructions.v1"},
        "raw_text_forbidden": {"const": true},
        "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
      }
    },
    "package": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "project_file",
        "source_root",
        "api_version",
        "fixture_bindings",
        "source_adapters",
        "generated_members"
      ],
      "properties": {
        "project_file": {"const": "sfdx-project.json"},
        "source_root": {"const": "package"},
        "api_version": {"const": "60.0"},
        "fixture_bindings": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "fixture",
              "fixture_sha256",
              "package_member",
              "package_member_sha256"
            ],
            "properties": {
              "fixture": {"type": "string", "pattern": "^fixtures/"},
              "fixture_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
              "package_member": {
                "type": "string",
                "pattern": "^package/main/default/"
              },
              "package_member_sha256": {
                "type": "string",
                "pattern": "^[a-f0-9]{64}$"
              }
            }
          }
        },
        "source_adapters": {
          "type": "array",
          "items": {"type": "object"}
        },
        "generated_members": {
          "type": "array",
          "minItems": 8,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["path", "sha256"],
            "properties": {
              "path": {"type": "string", "pattern": "^package/main/default/"},
              "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
            }
          }
        }
      }
    },
    "apex": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required",
        "test_class",
        "test_level",
        "command",
        "assertions"
      ],
      "properties": {
        "required": {"type": "boolean"},
        "test_class": {"type": ["string", "null"]},
        "test_level": {"type": ["string", "null"]},
        "command": {"type": ["string", "null"]},
        "assertions": {"type": "array", "minItems": 1, "items": {"type": "string"}}
      }
    },
    "queries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "engine",
          "statement",
          "bindings",
          "read_only",
          "assertions",
          "runner"
        ],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "engine": {"enum": ["soql", "cypher"]},
          "statement": {"type": "string", "minLength": 1},
          "bindings": {"type": "object"},
          "read_only": {"const": true},
          "assertions": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string"}
          },
          "runner": {
            "type": "object",
            "additionalProperties": false,
            "required": ["path", "sha256", "command"],
            "properties": {
              "path": {"const": "../../tools/run_query.py"},
              "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
              "command": {"type": "string", "minLength": 1}
            }
          }
        }
      }
    },
    "seed": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "script",
        "script_sha256",
        "declared_bindings",
        "command",
        "output",
        "idempotency"
      ],
      "properties": {
        "script": {"const": "scripts/seed.apex"},
        "script_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "declared_bindings": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"}
        },
        "command": {"type": "string", "minLength": 1},
        "output": {"type": "object"},
        "idempotency": {"const": "fresh_scratch_org_once_per_case"}
      }
    },
    "metadata_probe": {
      "type": ["object", "null"]
    },
    "browser": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required",
        "runner",
        "driver",
        "driver_path",
        "driver_sha256",
        "command",
        "entrypoint",
        "base_url",
        "route",
        "authentication",
        "inputs",
        "selectors",
        "scenario",
        "artifacts"
      ],
      "properties": {
        "required": {"const": true},
        "runner": {"const": "playwright"},
        "driver": {"const": "jataka.salesforce.case.v1"},
        "driver_path": {"const": "../../tools/run_browser_case.mjs"},
        "driver_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "command": {"type": "string", "minLength": 1},
        "entrypoint": {"type": "string", "pattern": "^SF-FID-[0-9]{3}$"},
        "base_url": {"type": "string", "minLength": 1},
        "route": {"const": "/apex/FidelityBenchmark"},
        "authentication": {"const": "sf_frontdoor_url"},
        "inputs": {"type": "object"},
        "selectors": {
          "type": "object",
          "additionalProperties": false,
          "required": ["action", "result"],
          "properties": {
            "action": {"type": "string", "minLength": 1},
            "result": {"type": "string", "minLength": 1}
          }
        },
        "scenario": {
          "type": "object",
          "additionalProperties": false,
          "required": ["setup", "actions", "assertions"],
          "properties": {
            "setup": {"type": "array", "items": {"type": "string"}},
            "actions": {"type": "array", "minItems": 1, "items": {"type": "string"}},
            "assertions": {
              "type": "array",
              "minItems": 1,
              "items": {"type": "string"}
            }
          }
        },
        "artifacts": {"type": "array", "minItems": 3, "items": {"type": "string"}}
      }
    },
    "event_replay": {
      "type": ["object", "null"]
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["precomputed_results", "required", "pass_source"],
      "properties": {
        "precomputed_results": {"const": false},
        "required": {"type": "array", "minItems": 7, "items": {"type": "string"}},
        "pass_source": {"const": "observed_runtime_only"}
      }
    },
    "prerequisites": {
      "type": "array",
      "minItems": 2,
      "items": {"type": "string"}
    }
  }
}
